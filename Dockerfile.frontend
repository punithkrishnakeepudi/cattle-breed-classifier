FROM node:18-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json ./
RUN npm install

# Copy only the source files needed to run the dev server
COPY src/ ./src/
COPY public/ ./public/
COPY index.html ./
COPY vite.config.js ./
COPY eslint.config.js ./

# Fix ownership of the app directory so Vite can create temporary files
RUN chown -R node:node /app

USER node

EXPOSE 3001

CMD ["npm", "run", "dev"]
